{
  "name": "playwright_practice",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:chronium": "playwright test --project= chronium",
    "test:firefox": "playwright test --project= firefox",
    "test:webkit": "playwright test --project= webkit",
    "test:mobile": "playwright test --project= mobile Chrome",
    "test:saucedemo": "Test_SITE=saucedemo playwright test tests/saucedemo.spec.ts --headed",
    "test:todomvc": "Test_SITE=todomvc playwright test tests/todomvc.spec.ts --headed",
    "test:parallel": "playwright test --workers=4",
    "test:serial": "playwright test --serial=1",
    "report": "playwright show-report",
    "codegen": "playwright codegen",
    "codegen:saucedemo": "playwright codegen https://www.saucedemo.com",
    "codegen:todomvc": "playwright todomvc https://demo.playwright.dev/todomvc",
    "install:browsers": "playwright install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@playwright/test": "^1.58.1",
    "@types/node": "^25.1.0",
    "dotenv": "^17.3.1"
  }
}
